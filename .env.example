# Supabase project URL, e.g. https://abcdxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Never import in client code.
SUPABASE_SERVICE_ROLE_KEY=

# The single email allowed to access /admin. Any other signed-in user is rejected.
ADMIN_EMAIL=
